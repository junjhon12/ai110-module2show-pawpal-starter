classDiagram
    class Task {
        +String name
        +int duration_min
        +String time
        +String priority
        +String frequency
        +Date due_date
        +Boolean done
        +mark_complete() void
    }
    
    class Pet {
        +String name
        +String species
        +String breed
        +int age
        +int xp
        +int level
        +String health
        +String mood
        +int speed
        +int endurance
        +int intelligence
        +Task[] tasks
        +add_task(task: Task) void
        +xp_to_next() int
        +xp_progress() float
        +add_xp(amount: int) bool
    }
    
    class Owner {
        +String name
        +int minutes_available
        +Pet[] pets
        +add_pet(pet: Pet) void
        +save_to_json(path: str) void
        +load_from_json(path: str)$ Owner
    }
    
    class Scheduler {
        +Owner owner
        -_get_all_tasks() list
        +sort_by_time() list
        +filter_tasks(pet_name, done) list
        +complete_task(pet, task) Task
        +detect_conflicts() list
        +build_plan() list
        +next_available_slot(duration_min, day_start, day_end) str
        +explain() str
    }

    Pet "1" *-- "many" Task : Has
    Owner "1" *-- "many" Pet : Owns
